[Unit]
Description=Task Tracker Application Backend
After=network.target postgresql.service mywebapp.socket
Requires=postgresql.service mywebapp.socket

[Service]
Type=simple
User=app
Group=app
WorkingDirectory=/opt/mywebapp
Environment=CONFIG_PATH=/etc/mywebapp/config.json

ExecStartPre=/usr/bin/node /opt/mywebapp/db/migrate.js
ExecStart=/usr/bin/node /opt/mywebapp/server.js

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target